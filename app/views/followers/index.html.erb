<section class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Feed</h1>
    <%= form_with url: feed_index_path, method: :get, local: true, class: "d-flex gap-2" do |form| %>
      <%= form.text_field :query, value: params[:query], placeholder: "Search username", class: "form-control" %>
      <%= form.submit "Search", class: "btn btn-primary" %>
    <% end %>
  </div>

  <div class="row g-4">
    <% @users.each do |user| %>
      <% vinyl = user.favorite_vinyl || user.user_vinyls.last&.vinyl %>
      <% follow = @follows[user.id] %>

      <div class="col-12 col-md-6 col-xl-4">
        <article class="card h-100 shadow-sm">
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div class="d-flex align-items-center gap-3">
                <img
                  src="https://ui-avatars.com/api/?name=<%= user.username %>&background=071013&color=F4F4F4&size=96"
                  alt="<%= user.username %>"
                  width="56"
                  height="56"
                  class="rounded-circle"
                >
                <div>
                  <h2 class="h5 mb-0"><%= user.username %></h2>
                  <p class="text-muted mb-0"><%= user.email %></p>
                  <% if user.favorite_genre.present? %>
                    <p class="mb-0 small"><strong>Favorite genre:</strong> <%= user.favorite_genre %></p>
                  <% end %>
                </div>
              </div>

              <% if follow %>
                <%= button_to "Following", follower_path(follow), method: :delete, class: "btn btn-outline-dark" %>
              <% else %>
                <%= button_to "Follow", followers_path(followed_id: user.id), method: :post, class: "btn btn-dark" %>
              <% end %>
            </div>

            <% if vinyl.present? %>
              <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="img-fluid rounded mb-3">

              <h3 class="h5 mb-1"><%= vinyl.title %></h3>
              <p class="mb-1"><strong>Artist:</strong> <%= vinyl.artist %></p>
              <p class="mb-1"><strong>Year:</strong> <%= vinyl.year %></p>
              <p class="mb-0"><strong>Genre:</strong> <%= vinyl.genre %></p>
            <% else %>
              <div class="border rounded p-4 text-muted">
                No favorite vinyl picked yet.
              </div>
            <% end %>
          </div>
        </article>
      </div>
    <% end %>
  </div>
</section>
