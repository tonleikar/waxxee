<section class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">Feed</h1>
      <p class="text-muted mb-0">Recent saves from the people you follow.</p>
    </div>

    <%= link_to "Find users", users_path, class: "btn btn-secondary" %>
  </div>

  <% if @feed_items.any? %>
    <div class="row g-4">
      <% @feed_items.each do |user_vinyl| %>
        <% user = user_vinyl.user %>
        <% vinyl = user_vinyl.vinyl %>

        <div class="col-12 col-md-6 col-xl-4">
          <article class="card h-100 shadow-sm">
            <div class="card-body">
              <div class="d-flex align-items-center gap-3 mb-3">
                <%= link_to profile_path(user), class: "text-decoration-none flex-shrink-0" do %>
                  <img
                    src="<%= user.avatar_url.presence || "https://ui-avatars.com/api/?name=#{ERB::Util.url_encode(user.username.to_s)}&background=071013&color=F4F4F4&size=96" %>"
                    alt="<%= user.username %>"
                    width="56"
                    height="56"
                    class="rounded-circle"
                  >
                <% end %>

                <div>
                  <p class="mb-0">
                    <%= link_to profile_path(user), class: "text-decoration-none text-reset fw-semibold" do %>
                      <%= user.name.presence || user.username %>
                    <% end %>
                    saved a record
                  </p>
                  <p class="text-muted mb-0 small">
                    @<%= user.username %> • <%= time_ago_in_words(user_vinyl.created_at) %> ago
                  </p>
                </div>
              </div>

              <%= link_to profile_path(user), class: "text-decoration-none text-reset d-block" do %>
                <div class="feed-card-media mb-3">
                  <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="feed-card-image">
                </div>

                <h2 class="h5 mb-1"><%= vinyl.title %></h2>
                <p class="mb-1"><strong>Artist:</strong> <%= vinyl.artist %></p>
                <% if vinyl.year_known? %>
                  <p class="mb-1"><strong>Year:</strong> <%= vinyl.display_year %></p>
                <% end %>
                <p class="mb-0"><strong>Genre:</strong> <%= vinyl.genre %></p>
              <% end %>
            </div>
          </article>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="border rounded p-4 text-center text-muted">
      <p class="mb-2">Your feed is empty.</p>
      <p class="mb-3">Follow users to see the records they save to their collection.</p>
      <%= link_to "Search users", users_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</section>
