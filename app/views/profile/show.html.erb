<section class="container py-4 profile-page" <%= %(data-controller="vinyl-picker") if @own_profile %>>
  <div class="card border-0 shadow-sm profile-hero">
    <div class="card-body p-4">
      <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-4">
        <div class="d-flex align-items-center gap-4">
          <img
            src="<%= @user.avatar_url.presence || "https://ui-avatars.com/api/?name=#{ERB::Util.url_encode(@user.username.to_s)}&background=071013&color=F4F4F4&size=160" %>"
            alt="<%= @user.username %>"
            class="profile-avatar"
          >
          <div>
            <p class="text-uppercase small text-muted mb-1">Profile</p>
            <h1 class="display-6 mb-1"><%= @user.name.presence || @user.username %></h1>
            <p class="mb-2 text-muted">@<%= @user.username %></p>
            <div class="d-flex flex-wrap gap-2">
              <span class="badge text-bg-light">Favorite genre: <%= @user.favorite_genre %></span>
              <span class="badge text-bg-light"><%= @vinyls.count %> saved vinyls</span>
              <span class="badge text-bg-light"><%= @user.followers.count %> followers</span>
              <span class="badge text-bg-light"><%= @user.following.count %> following</span>
            </div>
          </div>
        </div>

        <% if @own_profile %>
          <div class="d-flex flex-wrap gap-2 profile-actions">
            <%= link_to "Edit Profile", edit_profile_path(@user), class: "btn btn-dark profile-edit-button" %>
            <%= link_to "Log out",
                        destroy_user_session_path,
                        data: { turbo_method: :delete },
                        class: "btn btn-outline-dark profile-logout-button" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row g-4 mt-1">
    <div class="col-12 col-lg-5">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
              <p class="text-uppercase small text-muted mb-2">Favorite Vinyl</p>
              <p class="text-muted mb-0 small">This record is shown on your feed card.</p>
            </div>

            <% if @own_profile %>
              <button
                type="button"
                class="btn btn-outline-dark"
                data-bs-toggle="offcanvas"
                data-bs-target="#favoriteVinylPicker"
                aria-controls="favoriteVinylPicker"
              >
                Pick favorite
              </button>
            <% end %>
          </div>

          <div data-vinyl-picker-target="preview">
            <% if @favorite_vinyl.present? %>
              <img src="<%= @favorite_vinyl.artwork_url %>" alt="<%= @favorite_vinyl.title %>" class="img-fluid rounded mb-3">
              <h2 class="h4 mb-1"><%= @favorite_vinyl.title %></h2>
              <p class="mb-1"><strong>Artist:</strong> <%= @favorite_vinyl.artist %></p>
              <p class="mb-1"><strong>Year:</strong> <%= @favorite_vinyl.year %></p>
              <p class="mb-0"><strong>Genre:</strong> <%= @favorite_vinyl.genre %></p>
            <% else %>
              <div class="profile-empty-state">
                <%= @own_profile ? "Pick a favorite vinyl from your collection." : "No favorite vinyl picked yet." %>
              </div>
            <% end %>
          </div>

          <% if @own_profile %>
            <%= form_with model: @user, url: profile_path(@user), method: :patch, class: "mt-3", data: { vinyl_picker_target: "form" } do |form| %>
              <%= form.hidden_field :favorite_vinyl_id, data: { vinyl_picker_target: "input" } %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-7">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <p class="text-uppercase small text-muted mb-3">Collection Preview</p>
          <div class="row g-3">
            <% @vinyls.first(3).each do |vinyl| %>
              <div class="col-6 col-md-4">
                <article class="profile-vinyl-tile">
                  <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="img-fluid rounded mb-2">
                  <h3 class="h6 mb-1"><%= vinyl.title %></h3>
                  <p class="small text-muted mb-0"><%= vinyl.artist %></p>
                </article>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-4">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
        <div>
          <p class="text-uppercase small text-muted mb-1">Following</p>
          <p class="text-muted mb-0 small">People this profile follows.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
          <% if @own_profile %>
            <%= link_to "Find users", users_path, class: "btn btn-outline-dark btn-sm" %>
          <% end %>
          <span class="badge text-bg-light"><%= @following_users.count %> following</span>
        </div>
      </div>

      <% if @following_users.any? %>
        <div class="row g-4">
          <% @following_users.each do |followed_user| %>
            <% followed_vinyl = followed_user.favorite_vinyl || followed_user.user_vinyls.last&.vinyl %>

            <div class="col-12 col-md-6 col-xl-4">
              <%= link_to profile_path(followed_user), class: "text-decoration-none text-reset d-block h-100" do %>
                <article class="card h-100 shadow-sm">
                  <div class="card-body">
                    <div class="d-flex align-items-center gap-3 mb-3">
                      <img
                        src="<%= followed_user.avatar_url.presence || "https://ui-avatars.com/api/?name=#{ERB::Util.url_encode(followed_user.username.to_s)}&background=071013&color=F4F4F4&size=160" %>"
                        alt="<%= followed_user.username %>"
                        width="56"
                        height="56"
                        class="rounded-circle"
                      >
                      <div>
                        <h3 class="h5 mb-0"><%= followed_user.name.presence || followed_user.username %></h3>
                        <p class="text-muted mb-0">@<%= followed_user.username %></p>
                        <% if followed_user.favorite_genre.present? %>
                          <p class="mb-0 small"><strong>Favorite genre:</strong> <%= followed_user.favorite_genre %></p>
                        <% end %>
                      </div>
                    </div>

                    <% if followed_vinyl.present? %>
                      <img src="<%= followed_vinyl.artwork_url %>" alt="<%= followed_vinyl.title %>" class="img-fluid rounded mb-3">

                      <h4 class="h5 mb-1"><%= followed_vinyl.title %></h4>
                      <p class="mb-1"><strong>Artist:</strong> <%= followed_vinyl.artist %></p>
                      <p class="mb-1"><strong>Year:</strong> <%= followed_vinyl.year %></p>
                      <p class="mb-0"><strong>Genre:</strong> <%= followed_vinyl.genre %></p>
                    <% else %>
                      <div class="border rounded p-4 text-muted">
                        No favorite vinyl picked yet.
                      </div>
                    <% end %>
                  </div>
                </article>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="profile-empty-state">
          This profile is not following anyone yet.
        </div>
      <% end %>
    </div>
  </div>

  <% if @own_profile %>
    <div
      class="offcanvas offcanvas-bottom profile-vinyl-offcanvas"
      tabindex="-1"
      id="favoriteVinylPicker"
      aria-labelledby="favoriteVinylPickerLabel"
    >
      <div class="offcanvas-header">
        <div>
          <p class="text-uppercase small text-muted mb-1">Favorite vinyl</p>
          <h2 class="h4 mb-0" id="favoriteVinylPickerLabel">Choose a record</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>

      <div class="offcanvas-body">
        <input
          type="text"
          class="form-control mb-3"
          placeholder="Search title or artist"
          data-action="input->vinyl-picker#filter"
          data-vinyl-picker-target="search"
        >

        <div class="profile-vinyl-picker-results">
          <% @vinyls.each do |vinyl| %>
            <button
              type="button"
              class="profile-vinyl-result"
              data-action="click->vinyl-picker#select"
              data-vinyl-picker-option-id="<%= vinyl.id %>"
              data-vinyl-picker-id-param="<%= vinyl.id %>"
              data-vinyl-picker-title-param="<%= vinyl.title %>"
              data-vinyl-picker-artist-param="<%= vinyl.artist %>"
              data-vinyl-picker-year-param="<%= vinyl.year %>"
              data-vinyl-picker-image-param="<%= vinyl.artwork_url %>"
              data-vinyl-picker-search="<%= [vinyl.title, vinyl.artist].join(" ").downcase %>"
              data-bs-dismiss="offcanvas"
              aria-pressed="<%= @favorite_vinyl&.id == vinyl.id ? "true" : "false" %>"
            >
              <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="profile-vinyl-result-image">
              <span class="profile-vinyl-result-copy">
                <span class="profile-vinyl-result-title-row">
                  <strong><%= vinyl.title %></strong>
                  <span class="profile-vinyl-selected-badge <%= "d-none" unless @favorite_vinyl&.id == vinyl.id %>" data-vinyl-picker-selected-badge>
                    Selected
                  </span>
                </span>
                <span><%= vinyl.artist %></span>
                <span><%= vinyl.year %> • <%= vinyl.genre %></span>
              </span>
            </button>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</section>
