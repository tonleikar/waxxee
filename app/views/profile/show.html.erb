<section class="container py-4 profile-page" data-controller="<%= ["profile-layout", ("vinyl-picker" if @own_profile)].compact.join(" ") %>">
  <div class="card profile-hero">
    <div class="card-body p-4">
      <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-4">
        <div class="d-flex align-items-center gap-4 profile-identity">
          <img
            src="<%= @user.avatar_url.presence || "https://ui-avatars.com/api/?name=#{ERB::Util.url_encode(@user.username.to_s)}&background=071013&color=F4F4F4&size=160" %>"
            alt="<%= @user.username %>"
            class="profile-avatar"
          >
          <div>
            <h1 class="display-6 mb-1"><%= @user.name.presence || @user.username %></h1>
            <p class="mb-3 text-muted">@<%= @user.username %></p>
            <div class="profile-stat-row">
              <span class="profile-stat-chip"><%= @vinyls.count %> saved records</span>
              <span class="profile-stat-chip"><%= @user.followers.count %> followers</span>
              <span class="profile-stat-chip"><%= @user.following.count %> following</span>
            </div>
          </div>
        </div>

        <% if @own_profile %>
          <%= link_to edit_profile_path(@user), class: "profile-settings-button", "aria-label": "Edit profile settings" do %>
            <%= image_tag "cog.svg", alt: "", aria: { hidden: true }, class: "profile-settings-icon" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row g-4 mt-1 profile-top-row">
    <div class="col-12 col-lg-5">
      <div class="card profile-panel" data-profile-layout-target="favoriteCard">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
              <p class="profile-kicker mb-2">Favorite Record</p>
              <p class="text-muted mb-0 small">This record is shown on your feed card.</p>
            </div>

            <% if @own_profile %>
              <button
                type="button"
                class="btn btn-secondary"
                data-bs-toggle="offcanvas"
                data-bs-target="#favoriteVinylPicker"
                aria-controls="favoriteVinylPicker"
              >
                Pick favorite
              </button>
            <% end %>
          </div>

          <div data-vinyl-picker-target="preview">
            <% if @favorite_vinyl.present? %>
              <div class="profile-picked-vinyl">
                <img src="<%= @favorite_vinyl.artwork_url %>" alt="<%= @favorite_vinyl.title %>" class="profile-picked-vinyl-image">
                <div>
                  <h3 class="h4 mb-1"><%= @favorite_vinyl.title %></h3>
                  <p class="mb-1"><strong>Artist:</strong> <%= @favorite_vinyl.artist %></p>
                  <% if @favorite_vinyl.year_known? %>
                    <p class="mb-1"><strong>Year:</strong> <%= @favorite_vinyl.display_year %></p>
                  <% end %>
                  <p class="mb-0"><strong>Genre:</strong> <%= @favorite_vinyl.genre %></p>
                </div>
              </div>
            <% else %>
              <div class="profile-empty-state">
                <%= @own_profile ? "Pick a favorite record from your collection." : "No favorite record picked yet." %>
              </div>
            <% end %>
          </div>

          <% if @own_profile %>
            <%= form_with model: @user, url: profile_path(@user), method: :patch, class: "mt-3", data: { vinyl_picker_target: "form" } do |form| %>
              <%= form.hidden_field :favorite_vinyl_id, data: { vinyl_picker_target: "input" } %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-7 profile-side-column">
      <div class="d-flex flex-column gap-4 profile-side-stack" data-profile-layout-target="sideStack">
        <div class="card profile-panel">
          <div class="card-body p-4">
            <p class="profile-kicker mb-3">Collection Preview</p>
            <% preview_vinyls = @vinyls.first(3) %>

            <% if preview_vinyls.any? %>
              <div
                id="profileCollectionPreviewCarousel"
                class="carousel slide d-lg-none"
                data-profile-layout-target="collectionCarousel"
              >
                <div class="carousel-inner">
                  <% preview_vinyls.each_with_index do |vinyl, index| %>
                    <div class="carousel-item <%= "active" if index.zero? %>">
                      <article class="profile-vinyl-tile profile-vinyl-tile-mobile">
                        <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="img-fluid rounded mb-2">
                        <h3 class="h6 mb-1"><%= vinyl.title %></h3>
                        <p class="small text-muted mb-0"><%= vinyl.artist %></p>
                      </article>
                    </div>
                  <% end %>
                </div>
              </div>

              <div class="row g-3 d-none d-lg-flex">
                <% preview_vinyls.each do |vinyl| %>
                  <div class="col-6 col-md-4">
                    <article class="profile-vinyl-tile">
                      <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="img-fluid rounded mb-2">
                      <h3 class="h6 mb-1"><%= vinyl.title %></h3>
                      <p class="small text-muted mb-0"><%= vinyl.artist %></p>
                    </article>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="profile-empty-state">
                No records in this collection yet.
              </div>
            <% end %>
          </div>
        </div>

        <div class="card profile-panel profile-following-panel">
          <div class="card-body p-4 profile-following-body">
            <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
              <div>
                <p class="profile-kicker mb-1">Following</p>
                <p class="text-muted mb-0 small">People this profile follows.</p>
              </div>
              <div class="d-flex align-items-center gap-2">
                <% if @own_profile %>
                  <%= link_to "Find users", users_path, class: "btn btn-secondary" %>
                <% end %>
              </div>
            </div>

            <% if @following_users.any? %>
              <div class="row g-4 profile-following-grid">
                <% @following_users.each do |followed_user| %>
                  <div class="col-12 col-md-6">
                    <%= link_to profile_path(followed_user), class: "text-decoration-none text-reset d-block h-100" do %>
                      <article class="card h-100 profile-follow-card">
                        <div class="card-body">
                          <div class="d-flex align-items-center gap-3">
                            <img
                              src="<%= followed_user.avatar_url.presence || "https://ui-avatars.com/api/?name=#{ERB::Util.url_encode(followed_user.username.to_s)}&background=071013&color=F4F4F4&size=160" %>"
                              alt="<%= followed_user.username %>"
                              width="56"
                              height="56"
                              class="profile-follow-avatar"
                            >
                            <div>
                              <h3 class="h5 mb-0"><%= followed_user.name.presence || followed_user.username %></h3>
                              <p class="text-muted mb-0">@<%= followed_user.username %></p>
                            </div>
                          </div>
                        </div>
                      </article>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="profile-empty-state">
                This profile is not following anyone yet.
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card profile-panel mt-4">
    <div class="card-body p-4">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-4">
        <div>
          <p class="profile-kicker mb-1">Taste Personas</p>
          <p class="text-muted mb-0 small">AI-generated record-discovery personas based on this profile's taste.</p>
        </div>
      </div>

      <% if @personas.any? %>
        <div class="row g-4">
          <% @personas.each do |persona| %>
            <div class="col-12 col-xl-6">
              <article class="card h-100 profile-persona-card">
                <div class="card-body">
                  <div class="mb-3">
                    <h3 class="h4 mb-0"><%= persona.title %></h3>
                  </div>

                  <div class="profile-persona-meta mb-3">
                    <span class="profile-stat-chip"><%= persona.min_year %>-<%= persona.max_year %></span>
                    <% Array(persona.genres).each do |genre| %>
                      <span class="profile-stat-chip"><%= genre %></span>
                    <% end %>
                  </div>

                  <div class="d-flex flex-wrap gap-2">
                    <%= link_to "Open in swiper", swiper_index_path(persona_id: persona.id), class: "btn btn-secondary" %>
                  </div>
                </div>
              </article>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="profile-empty-state">
          <%= @own_profile ? "Save records or create a custom persona to build your discovery lanes." : "No taste personas generated yet." %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @own_profile %>
    <div
      class="offcanvas offcanvas-bottom profile-vinyl-offcanvas"
      tabindex="-1"
      id="favoriteVinylPicker"
      aria-labelledby="favoriteVinylPickerLabel"
    >
      <div class="offcanvas-header">
        <div>
          <h2 class="h4 mb-0" id="favoriteVinylPickerLabel">Choose a record</h2>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>

      <div class="offcanvas-body">
        <input
          type="text"
          class="form-control mb-3"
          placeholder="Search title or artist"
          data-action="input->vinyl-picker#filter"
          data-vinyl-picker-target="search"
        >

        <div class="profile-vinyl-picker-results">
          <% @vinyls.each do |vinyl| %>
            <button
              type="button"
              class="profile-vinyl-result"
              data-action="click->vinyl-picker#select"
              data-vinyl-picker-option-id="<%= vinyl.id %>"
              data-vinyl-picker-id-param="<%= vinyl.id %>"
              data-vinyl-picker-title-param="<%= vinyl.title %>"
              data-vinyl-picker-artist-param="<%= vinyl.artist %>"
              data-vinyl-picker-year-param="<%= vinyl.display_year %>"
              data-vinyl-picker-genre-param="<%= vinyl.genre %>"
              data-vinyl-picker-image-param="<%= vinyl.artwork_url %>"
              data-vinyl-picker-search="<%= [vinyl.title, vinyl.artist].join(" ").downcase %>"
              aria-pressed="<%= @favorite_vinyl&.id == vinyl.id ? "true" : "false" %>"
            >
              <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="profile-vinyl-result-image">
              <span class="profile-vinyl-result-copy">
                <span class="profile-vinyl-result-title-row">
                  <strong><%= vinyl.title %></strong>
                  <span class="profile-vinyl-selected-badge <%= "d-none" unless @favorite_vinyl&.id == vinyl.id %>" data-vinyl-picker-selected-badge>
                    Selected
                  </span>
                </span>
                <span><%= vinyl.artist %></span>
                <% metadata = [vinyl.display_year, vinyl.genre.presence].compact.join(" • ") %>
                <% if metadata.present? %>
                  <span><%= metadata %></span>
                <% end %>
              </span>
            </button>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</section>
