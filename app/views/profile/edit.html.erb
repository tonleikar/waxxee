<section class="container py-4 profile-page">
  <div class="card profile-panel">
    <div class="card-body p-4 p-lg-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <p class="profile-kicker mb-1">Settings</p>
          <h1 class="h2 mb-0">Edit Profile</h1>
        </div>
        <%= link_to "Back", profile_path(@user), class: "btn btn-secondary" %>
      </div>

      <div class="row g-4">
        <div class="col-12 col-lg-4">
          <div class="profile-edit-sidebar d-grid gap-4">
            <div
              class="profile-avatar-panel"
              data-controller="profile-avatar"
              data-profile-avatar-preview-url-value="<%= avatar_preview_profile_path(@user) %>"
              data-profile-avatar-current-source-type-value="<%= @user.avatar_source_type %>"
            >
              <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <div>
                  <p class="profile-kicker mb-1">Profile picture</p>
                  <h2 class="h5 mb-0">Generate a new portrait</h2>
                </div>
              </div>

              <img
                src="<%= @user.avatar_url.presence || "https://ui-avatars.com/api/?name=#{ERB::Util.url_encode(@user.username.to_s)}&background=071013&color=F4F4F4&size=320" %>"
                alt="Generated profile portrait preview"
                class="profile-avatar profile-avatar-large profile-avatar-generator-preview"
                data-profile-avatar-target="preview"
              >

              <p class="small text-muted mb-3">
                Click regenerate for a free random portrait, or upload your own image, then save it to Cloudinary for this profile.
              </p>

              <%= form_with model: @user, url: avatar_profile_path(@user), method: :patch, class: "d-grid gap-3", data: { action: "submit->profile-avatar#save" }, html: { multipart: true } do |avatar_form| %>
                <div data-profile-avatar-target="status" class="small text-muted d-none"></div>
                <%= avatar_form.hidden_field :avatar_source_url, data: { profile_avatar_target: "input" } %>
                <div>
                  <label class="form-label">Portrait type</label>
                  <input type="hidden" value="" data-profile-avatar-target="genderInput">
                  <div class="profile-avatar-filter-group" role="group" aria-label="Portrait type">
                    <button
                      type="button"
                      class="profile-avatar-filter is-active"
                      data-profile-avatar-target="genderButton"
                      data-action="click->profile-avatar#selectGender"
                      data-gender-value=""
                    >
                      Random
                    </button>
                    <button
                      type="button"
                      class="profile-avatar-filter"
                      data-profile-avatar-target="genderButton"
                      data-action="click->profile-avatar#selectGender"
                      data-gender-value="female"
                    >
                      Female
                    </button>
                    <button
                      type="button"
                      class="profile-avatar-filter"
                      data-profile-avatar-target="genderButton"
                      data-action="click->profile-avatar#selectGender"
                      data-gender-value="male"
                    >
                      Male
                    </button>
                  </div>
                </div>
                <%= button_tag "Regenerate",
                  type: "button",
                  class: "btn btn-secondary align-self-start",
                  data: { action: "click->profile-avatar#regenerate" } %>
                <div>
                  <%= avatar_form.label :avatar_file, "Upload image", class: "form-label" %>
                  <%= avatar_form.file_field :avatar_file,
                    accept: "image/*",
                    class: "form-control",
                    data: { profile_avatar_target: "fileInput", action: "change->profile-avatar#uploadPreview" } %>
                </div>
                <%= avatar_form.submit "Save profile picture", class: "btn btn-primary", data: { profile_avatar_target: "saveButton" } %>
              <% end %>

              <% if @user.avatar_url.present? %>
                <div>
                  <p class="profile-kicker mb-2">Current picture</p>
                  <img
                    src="<%= @user.avatar_url %>"
                    alt="<%= @user.username %>"
                    class="profile-avatar profile-avatar-current"
                    data-profile-avatar-target="current"
                  >
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div class="col-12 col-lg-8">
          <%= form_with model: @user, url: profile_path(@user), method: :patch, class: "row g-3" do |form| %>
            <div class="col-12 col-md-6">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control" %>
            </div>

            <div class="col-12 col-md-6">
              <%= form.label :username, class: "form-label" %>
              <%= form.text_field :username, class: "form-control" %>
            </div>

            <div class="col-12">
              <%= form.label :favorite_genre, class: "form-label" %>
              <%= form.select :favorite_genre, options_for_select(@genres, @user.favorite_genre), {}, class: "form-select" %>
            </div>

            <div class="col-12 d-flex justify-content-end">
              <%= form.submit "Save profile", class: "btn btn-primary px-4" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
