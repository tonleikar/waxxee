<section class="container py-4">
  <div class="mb-4">
    <div>
      <h1 class="h3 mb-0">Users</h1>
      <p class="text-muted mb-0">Find people to follow and explore their taste.</p>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="users-toolbar">
        <div class="users-toolbar-back">
          <%= link_to "Back to feed", followers_path, class: "btn btn-secondary" %>
        </div>

        <%= form_with url: users_path, method: :get, local: true, class: "vinyl-library-search-form users-search-form" do |form| %>
          <div class="vinyl-library-search-input-wrapper">
            <%= form.text_field :query, value: @query, placeholder: "Search username or email", class: "form-control vinyl-library-search-input" %>
          </div>

          <div class="vinyl-library-search-actions">
            <%= form.submit "Search", class: "btn btn-primary w-100" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if @users.any? %>
    <div class="row g-4">
      <% @users.each do |user| %>
        <% vinyl = user.favorite_vinyl || user.user_vinyls.last&.vinyl %>
        <% follow = @follows[user.id] %>

        <div class="col-12 col-md-6 col-xl-4">
          <article class="card h-100 shadow-sm">
            <div class="card-body">
              <div class="d-flex align-items-start justify-content-between mb-3 gap-3">
                <div class="d-flex align-items-center gap-3">
                  <img
                    src="<%= user.avatar_url.presence || "https://ui-avatars.com/api/?name=#{ERB::Util.url_encode(user.username.to_s)}&background=071013&color=F4F4F4&size=96" %>"
                    alt="<%= user.username %>"
                    width="56"
                    height="56"
                    class="rounded-circle"
                  >
                  <div>
                    <h2 class="h5 mb-0"><%= user.name.presence || user.username %></h2>
                    <p class="text-muted mb-0">@<%= user.username %></p>
                    <% if user.favorite_genre.present? %>
                      <p class="mb-0 small"><strong>Favorite genre:</strong> <%= user.favorite_genre %></p>
                    <% end %>
                  </div>
                </div>

                <div class="users-follow-toggle">
                  <% if follow %>
                    <%= button_to follower_path(follow),
                      method: :delete,
                      class: "follow-btn follow-btn--following",
                      aria: { label: "Unfollow #{user.username}" } do %>
                      <span class="follow-toggle__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" class="follow-toggle__heart" role="presentation" focusable="false">
                          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54z" />
                        </svg>
                      </span>
                    <% end %>
                  <% else %>
                    <%= button_to followers_path(followed_id: user.id),
                      method: :post,
                      class: "follow-btn",
                      aria: { label: "Follow #{user.username}" } do %>
                      <span class="follow-toggle__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" class="follow-toggle__heart" role="presentation" focusable="false">
                          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54z" />
                        </svg>
                      </span>
                    <% end %>
                  <% end %>
                </div>
              </div>

              <%= link_to profile_path(user), class: "text-decoration-none text-reset d-block" do %>
                <% if vinyl.present? %>
                  <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="img-fluid rounded mb-3">

                  <h3 class="h5 mb-1"><%= vinyl.title %></h3>
                  <p class="mb-1"><strong>Artist:</strong> <%= vinyl.artist %></p>
                  <% if vinyl.year_known? %>
                    <p class="mb-1"><strong>Year:</strong> <%= vinyl.display_year %></p>
                  <% end %>
                  <p class="mb-0"><strong>Genre:</strong> <%= vinyl.genre %></p>
                <% else %>
                  <div class="border rounded p-4 text-muted">
                    No favorite vinyl picked yet.
                  </div>
                <% end %>
              <% end %>
            </div>
          </article>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="border rounded p-4 text-center text-muted">
      <p class="mb-2">No users found.</p>
      <p class="mb-0">Try a different username or email.</p>
    </div>
  <% end %>
</section>
