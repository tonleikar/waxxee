<article class="vinyl-card swiper-sleeve"
         data-discogs-id="<%= vinyl.nil? ? '{{vinylid}}' : vinyl[:discogs_id] %>"
         aria-live="polite">
  <div class="randomizer-sleeve__body">
    <div class="randomizer-sleeve__face randomizer-sleeve__face--front">
      <div class="randomizer-sleeve__artwork-wrap">
        <%= image_tag(vinyl&.dig(:artwork_url).presence || "placeholder.png",
                      alt: "album cover",
                      class: "randomizer-sleeve__artwork album-img",
                      data: { swipe_field: "artwork" }) %>
      </div>

      <button type="button"
              class="randomizer-sleeve__flip"
              aria-label="Flip to details"
              data-action="click->swipe#flipToBack">
        <span aria-hidden="true">&#x21bb;</span>
      </button>
    </div>

    <div class="randomizer-sleeve__face randomizer-sleeve__face--back">
      <div class="randomizer-sleeve__back-header">
        <p class="randomizer-sleeve__eyebrow mb-1">Release details</p>
        <h2 class="randomizer-sleeve__back-title mb-0" data-swipe-field="title">
          <%= vinyl.nil? ? "{{title}}" : vinyl[:title] %>
        </h2>
      </div>

      <dl class="randomizer-sleeve__details">
        <div>
          <dt>Artist</dt>
          <dd data-swipe-field="artist"><%= vinyl.nil? ? "{{artist}}" : vinyl[:artist] %></dd>
        </div>
        <div data-swipe-field-row="year">
          <dt>Year</dt>
          <dd data-swipe-field="year"><%= vinyl.nil? ? "{{year}}" : vinyl[:year] %></dd>
        </div>
        <div>
          <dt>Genre</dt>
          <dd data-swipe-field="genre"><%= vinyl.nil? ? "{{genre}}" : vinyl[:genre] %></dd>
        </div>
      </dl>

      <p class="randomizer-sleeve__meta mb-0">Swipe right to save. Swipe left to pass.</p>

      <button type="button"
              class="randomizer-sleeve__flip randomizer-sleeve__flip--back"
              aria-label="Flip to cover"
              data-action="click->swipe#flipToFront">
        <span aria-hidden="true">&#x21ba;</span>
      </button>
    </div>
  </div>
</article>
