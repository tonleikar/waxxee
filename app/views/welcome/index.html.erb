<%= render "shared/header" %>

<div class="container home-dashboard">
  <h1 class="main-title">WELCOME BACK <%= current_user.username %>!</h1>
  <h2 class="home-dashboard__section-title">GO DIGGING...</h2>

  <section class="home-persona-section mb-5"
           data-controller="persona-form"
           data-persona-form-open-class="is-open">
    <div class="persona-grid mb-4">
      <% @saved_personas.each do |persona| %>
        <%= render "shared/persona_card",  persona: persona %>
      <% end %>

      <button type="button"
              class="persona-card persona-card--builder"
              data-persona-form-target="button"
              data-action="persona-form#toggle"
              aria-expanded="false">
        <div class="persona-card__thumbnail persona-card__thumbnail--builder">
          <span class="persona-card__years">Custom</span>
        </div>

        <div class="persona-card__body persona-card__body--builder">
          <div>
            <h2 class="persona-card__title mb-1"><%= @persona_builder_label %></h2>
            <p class="persona-card__meta mb-0">Generate a saved Waxxee persona.</p>
          </div>
        </div>

        <div class="persona-card__actions persona-card__actions--builder">
          <span class="persona-card__action persona-card__action--primary">Create</span>
        </div>
      </button>
    </div>

    <div class="home-persona-builder" data-persona-form-target="panel" hidden>
      <%= form_with url: personas_path, method: :post, class: "home-persona-builder__form" do |form| %>
        <%= form.hidden_field :return_to, name: "persona[return_to]", value: request.fullpath %>
        <%= form.hidden_field :redirect_to_swiper, name: "persona[redirect_to_swiper]", value: true %>

        <div class="home-persona-builder__field">
          <%= form.label :prompt, "Describe your taste", class: "form-label" %>
          <%= form.text_area :prompt,
                             name: "persona[prompt]",
                             rows: 4,
                             class: "form-control home-persona-builder__input",
                             data: { persona_form_target: "input" },
                             placeholder: "Example: Build me a warm 70s cosmic soul persona with jazzy edges, dub textures, and late-night energy." %>
        </div>

        <div class="home-persona-builder__actions">
          <p class="home-persona-builder__hint mb-0">The persona will be saved to your account.</p>
          <%= form.submit "Generate and save persona", class: "home-persona-builder__submit" %>
        </div>
      <% end %>
    </div>
  </section>
  <% if current_user.vinyls.any? %>
    <%= render "shared/recent_finds" %>
  <% end %>
</div>
