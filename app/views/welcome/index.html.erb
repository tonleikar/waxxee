<%= render "shared/header" %>

<div class="container home-dashboard">
  <section class="welcome-hero mb-5">
    <h2 class="welcome-hero__title">Welcome back, <%= current_user.username %></h2>
    <p class="welcome-hero__subtitle col-8">Rediscover the thrill of stumbling upon the unexpected and broaden your musical mind. Flick through curated staff picks or create your own persona for a truly custom crate digging experience.<br><br>Jump in and discover something amazing.</p>
  </section>

  <section class="home-persona-section mb-5">
    <div class="persona-accordion mb-4"
         data-controller="persona-form"
         data-persona-form-open-class="is-open">
      <button type="button"
              class="persona-accordion__trigger"
              data-persona-form-target="button"
              data-action="persona-form#toggle"
              aria-expanded="true">
        <h3 class="persona-accordion__label mb-0">STAFF PICKS</h3>
      </button>

      <div class="persona-accordion__panel" data-persona-form-target="panel" hidden>
        <div class="persona-grid">
          <% @staff_picks.each do |persona| %>
            <%= render "shared/staff_pick_card", persona: persona %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="persona-accordion"
         data-controller="persona-form"
         data-persona-form-open-class="is-open">
      <button type="button"
              class="persona-accordion__trigger"
              data-persona-form-target="button"
              data-action="persona-form#toggle"
              aria-expanded="false">
        <h3 class="persona-accordion__label mb-0">Personas</h3>
      </button>

      <div class="persona-accordion__panel" data-persona-form-target="panel" hidden>
        <div data-controller="persona-form"
             data-persona-form-open-class="is-open">
          <div class="persona-builder-card mb-4">
            <div class="persona-builder-card__body">
              <button type="button"
                      class="persona-builder-card__header"
                      data-persona-form-target="button"
                      data-action="persona-form#toggle"
                      aria-expanded="false">
                <span class="persona-builder-card__action">Define a new persona</span>
              </button>

              <div class="home-persona-builder" data-persona-form-target="panel" hidden>
                <%= form_with url: personas_path, method: :post, class: "home-persona-builder__form" do |form| %>
                  <%= form.hidden_field :return_to, name: "persona[return_to]", value: request.fullpath %>
                  <%= form.hidden_field :redirect_to_swiper, name: "persona[redirect_to_swiper]", value: true %>

                  <div class="home-persona-builder__field">
                    <%= form.text_area :prompt,
                                       name: "persona[prompt]",
                                       rows: 1,
                                       class: "form-control home-persona-builder__input",
                                       data: { persona_form_target: "input" },
                                       placeholder: "Describe in casual language what you want to dig for" %>
                  </div>

                  <div class="home-persona-builder__actions">
                    <%= form.submit "Go digging", class: "home-persona-builder__submit" %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>

          <div class="persona-grid mb-4">
            <% @saved_personas.each do |persona| %>
              <%= render "shared/persona_card",  persona: persona %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
