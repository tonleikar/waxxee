<section class="container py-4">
  <% unless user_signed_in? %>
  <div class="d-flex justify-content-end mb-3">
    <%= link_to "Log in", new_user_session_path, class: "btn btn-dark" %>
  </div>
  <% end %>

  <!-- Login box -->
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card p-4 shadow-sm">

        <h2 class="h5 text-center mb-3">Log in</h2>

        <%= form_with url: user_session_path, scope: :user, local: true do |f| %>

          <div class="mb-3">
            <%= f.email_field :email,
              placeholder: "Email",
              class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.password_field :password,
              placeholder: "Password",
              class: "form-control" %>
          </div>

          <%= f.submit "Log in", class: "btn btn-dark w-100" %>

        <% end %>

        <div class="text-center mt-3">
          <%= link_to "Create an account", new_user_registration_path %>
        </div>

      </div>
    </div>
  </div>

</section>
