<section class="container py-4">
  <% unless user_signed_in? %>
  <div class="d-flex justify-content-end mb-3">
    <%= link_to "Log in", new_user_session_path, class: "btn btn-dark" %>
  </div>
<% end %>

  <!-- Vinyl record -->
  <div class="d-flex justify-content-center mb-4">
    <%= link_to root_path(persona: "randomizer"),
                class: "randomizer-btn",
                "aria-label": "Randomizer record",
                data: {
                  controller: "randomizer",
                  action: "click->randomizer#start",
                  randomizer_loading_value: 1200,
                  randomizer_success_value: 900,
                  randomizer_dissipate_value: 700
                } do %>

      <div class="record-container">
        <div class="record">
          <div class="record-label">
            <div class="record-hole"></div>
          </div>
        </div>
      </div>

    <% end %>
  </div>

  <!-- Login box -->
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card p-4 shadow-sm">

        <h2 class="h5 text-center mb-3">Log in</h2>

        <%= form_with url: user_session_path, scope: :user, local: true do |f| %>

          <div class="mb-3">
            <%= f.email_field :email,
              placeholder: "Email",
              class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.password_field :password,
              placeholder: "Password",
              class: "form-control" %>
          </div>

          <%= f.submit "Log in", class: "btn btn-dark w-100" %>

        <% end %>

        <div class="text-center mt-3">
          <%= link_to "Create an account", new_user_registration_path %>
        </div>

      </div>
    </div>
  </div>

</section>
