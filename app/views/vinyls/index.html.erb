<section class="container py-4 vinyl-library-page">
  <div class="card border-0 shadow-sm vinyl-library-hero">
    <div class="card-body p-4">
      <div>
        <h1 class="display-6 mb-2">Your saved vinyls</h1>
        <p class="text-muted mb-0">These are the records you sent from swiper. Search, sort, and organize them into folders.</p>
      </div>
    </div>
  </div>

  <div class="row g-4 mt-1 align-items-stretch">
    <div class="col-12 col-xl-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
              <h2 class="h4 mb-0">Create crate</h2>
            </div>
          </div>

          <%= form_with model: Folder.new, url: collections_path, local: true, class: "vinyl-folder-create-form" do |form| %>
            <div>
              <%= form.text_field :name, class: "form-control", placeholder: "Create a crate", required: true %>
            </div>
            <div>
              <%= form.submit "Add crate", class: "btn btn-outline-dark w-100" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-8">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
              <h2 class="h4 mb-0">Your collections</h2>
            </div>
          </div>

        <div class="vinyl-folder-list">
  <% if @folders.any? %>
    <% @folders.each do |folder| %>
      <% latest_vinyl = folder.vinyls.order(created_at: :desc).first %>

      <div class="vinyl-folder-chip">
        <div class="vinyl-folder-chip-main">
          <% if latest_vinyl&.artwork_url.present? %>
            <img src="<%= latest_vinyl.artwork_url %>" alt="<%= folder.name %>" class="vinyl-folder-thumb">
          <% else %>
            <div class="vinyl-folder-thumb vinyl-folder-thumb-placeholder"></div>
          <% end %>

          <span>
            <strong><%= folder.name %></strong>
          </span>
        </div>

        <%= button_to collection_path(folder),
          method: :delete,
          class: "btn btn-sm vinyl-trash-btn" do %>
          <i class="fas fa-trash"></i>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="text-muted mb-0">No folders yet. Create one here, then add records from the cards.</p>
  <% end %>
</div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="vinyl-library-toolbar">
            <div class="vinyl-library-toolbar-search">
              <%= form_with url: vinyls_path, method: :get, local: true, class: "vinyl-library-search-form" do |form| %>
                <%= form.hidden_field :sort, value: @sort %>

                <div class="vinyl-library-search-input-wrapper">
                  <%= form.text_field :query, value: @query, placeholder: "Search title, artist, or genre", class: "form-control vinyl-library-search-input" %>
                  <i class="fas fa-search vinyl-library-search-icon"></i>
                </div>

                <div class="vinyl-library-search-actions">
                  <%= form.submit "Search", class: "btn btn-dark w-100" %>
                  <%= link_to "Clear", vinyls_path(sort: @sort), class: "btn btn-outline-dark w-100 d-none", id: "clear-search-btn" %>
                </div>
              <% end %>
            </div>

            <div class="vinyl-library-toolbar-sort">
              <%= form_with url: vinyls_path, method: :get, local: true do |form| %>
                <%= form.hidden_field :query, value: @query %>
                <%= form.select :sort,
                  options_for_select(
                    [
                      ["Recently added", "recent"],
                      ["Title Z-A", "title_desc"],
                      ["Title A-Z", "title_asc"],
                      ["Artist A-Z", "artist_asc"],
                      ["Artist Z-A", "artist_desc"],
                      ["Year newest", "year_desc"],
                      ["Year oldest", "year_asc"]
                    ],
                    @sort
                  ),
                  {},
                  class: "form-select vinyl-library-sort-select",
                  onchange: "this.form.requestSubmit()" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="row g-3">
        <% @vinyls.each do |vinyl| %>
          <% user_vinyl = @user_vinyls_by_vinyl_id[vinyl.id] %>
          <% vinyl_folder_ids = user_vinyl ? user_vinyl.folders.map(&:id) : [] %>

          <div class="col-12 col-md-6 col-xl-4">
            <article class="card border-0 shadow-sm h-100 vinyl-library-card">
              <img src="<%= vinyl.artwork_url %>" alt="<%= vinyl.title %>" class="vinyl-library-card-image">

              <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                  <div>
                    <h3 class="h4 mb-1"><%= vinyl.title %></h3>
                    <p class="text-muted mb-0"><%= vinyl.artist %></p>
                  </div>

                  <div class="d-flex flex-column align-items-end gap-2">
                    <% if vinyl.year.present? %>
                      <span class="badge text-bg-light"><%= vinyl.year %></span>
                    <% end %>

                    <% if user_vinyl.present? %>
                      <%= button_to user_vinyl_path(user_vinyl),
                        method: :delete,
                        class: "btn btn-sm vinyl-trash-btn" do %>
                        <i class="fas fa-trash"></i>
                      <% end %>
                    <% end %>
                  </div>
                </div>

                <p class="small text-muted mb-3"><%= vinyl.genre.presence || "Genre unknown" %></p>

                <div class="vinyl-folder-tags mb-3">
                  <% if vinyl_folder_ids.any? %>
                    <% user_vinyl.folders.each do |folder| %>
                      <span class="badge rounded-pill text-bg-dark"><%= folder.name %></span>
                    <% end %>
                  <% else %>
                    <span class="text-muted small">Not in any folder yet.</span>
                  <% end %>
                </div>

                <% if @folders.any? %>
                  <%= form_with url: folder_vinyls_path, method: :post, local: true, class: "row g-2 align-items-end" do |form| %>
                    <%= form.hidden_field :vinyl_id, name: "folder_vinyl[vinyl_id]", value: vinyl.id %>

                    <div class="col-8">
                      <label class="form-label small text-muted mb-1">Add to folder</label>
                      <%= select_tag "folder_vinyl[folder_id]",
                        options_for_select(@folders.reject { |folder| vinyl_folder_ids.include?(folder.id) }.map { |folder| [folder.name, folder.id] }),
                        include_blank: vinyl_folder_ids.size == @folders.size ? "Already in all folders" : "Choose folder",
                        class: "form-select",
                        disabled: vinyl_folder_ids.size == @folders.size %>
                    </div>

                    <div class="col-4">
                      <%= form.submit "Add", class: "btn btn-dark w-100", disabled: vinyl_folder_ids.size == @folders.size %>
                    </div>
                  <% end %>
                <% else %>
                  <p class="small text-muted mb-0">Create a folder first to organize this vinyl.</p>
                <% end %>
              </div>
            </article>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const searchInput = document.querySelector(".vinyl-library-search-input");
    const clearButton = document.querySelector("#clear-search-btn");

    if (!searchInput || !clearButton) return;

    function toggleClearButton() {
      if (searchInput.value.trim() === "") {
        clearButton.classList.add("d-none");
      } else {
        clearButton.classList.remove("d-none");
      }
    }

    searchInput.addEventListener("input", toggleClearButton);
    toggleClearButton();
  });
</script>
