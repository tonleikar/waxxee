<section class="container py-4 vinyl-library-page">
  <div class="mb-4">
    <div>
      <h1 class="h3 mb-0">Your saved vinyls</h1>
      <p class="text-muted mb-0">These are the records you sent from swiper. Search, sort, and organize them into folders.</p>
    </div>
  </div>

  <div class="row g-4 mt-1 align-items-stretch">
    <div class="col-12">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
              <h2 class="h4 mb-0">Your crates</h2>
            </div>

            <button
              class="btn btn-outline-dark d-md-none vinyl-folder-toggle"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#vinylCratesList"
              aria-expanded="false"
              aria-controls="vinylCratesList"
            >
              Show crates
            </button>
          </div>

          <%= form_with model: Folder.new, url: collections_path, local: true, class: "vinyl-folder-create-form mb-4" do |form| %>
            <div class="d-flex flex-nowrap gap-2 align-items-stretch">
              <div class="flex-grow-1 vinyl-folder-create-input-wrap">
                <%= form.text_field :name, class: "form-control", placeholder: "Create a crate", required: true %>
              </div>
              <div class="flex-shrink-0">
                <%= form.submit "Add crate", class: "btn btn-outline-dark" %>
              </div>
            </div>
          <% end %>

          <%= render "crates_list", folders: @folders %>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="vinyl-library-toolbar">
            <div class="vinyl-library-toolbar-search">
              <%= form_with url: vinyls_path, method: :get, local: true, class: "vinyl-library-search-form" do |form| %>
                <%= form.hidden_field :sort, value: @sort %>

                <div class="vinyl-library-search-input-wrapper">
                  <span class="vinyl-library-search-icon" aria-hidden="true">
                    <i class="fas fa-search"></i>
                  </span>
                  <%= form.text_field :query, value: @query, placeholder: "Search title, artist, or genre", class: "form-control vinyl-library-search-input" %>
                </div>

                <div class="vinyl-library-search-actions">
                  <%= form.submit "Search", class: "btn btn-dark w-100" %>
                  <%= link_to "Clear", vinyls_path(sort: @sort), class: "btn btn-outline-dark w-100", id: "clear-search-btn" %>
                </div>
              <% end %>
            </div>

            <div class="vinyl-library-toolbar-sort">
              <%= form_with url: vinyls_path, method: :get, local: true, html: { class: "vinyl-library-sort-form" } do |form| %>
                <%= form.hidden_field :query, value: @query %>
                <div class="vinyl-library-sort-shell">
                  <span class="vinyl-library-sort-icon" aria-hidden="true">
                    <i class="fas fa-sort"></i>
                  </span>
                  <%= form.select :sort,
                    options_for_select(
                      [
                        ["Recently added", "recent"],
                        ["Title Z-A", "title_desc"],
                        ["Title A-Z", "title_asc"],
                        ["Artist A-Z", "artist_asc"],
                        ["Artist Z-A", "artist_desc"],
                        ["Year newest", "year_desc"],
                        ["Year oldest", "year_asc"]
                      ],
                      @sort
                    ),
                    {},
                    class: "form-select vinyl-library-sort-select",
                    onchange: "this.form.requestSubmit()" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="row g-3">
        <% @vinyls.each do |vinyl| %>
          <% user_vinyl = @user_vinyls_by_vinyl_id[vinyl.id] %>
          <% vinyl_folder_ids = user_vinyl ? user_vinyl.folders.map(&:id) : [] %>

          <div class="col-12 col-md-6 col-xl-4">
            <%= render "vinyl_card",
              vinyl: vinyl,
              user_vinyl: user_vinyl,
              vinyl_folder_ids: vinyl_folder_ids,
              folders: @folders %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<% @folders.each do |folder| %>
  <div class="modal fade vinyl-folder-modal" id="crateModal-<%= folder.id %>" tabindex="-1" aria-labelledby="crateModalLabel-<%= folder.id %>" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen-lg-down modal-xl modal-dialog-centered modal-dialog-scrollable">
      <div class="modal-content vinyl-folder-modal-content border-0">
        <div class="modal-header vinyl-folder-modal-header border-0">
          <div>
            <p class="vinyl-library-card-kicker mb-2">Crate</p>
            <h2 class="modal-title h3 mb-1" id="crateModalLabel-<%= folder.id %>"><%= folder.name %></h2>
            <p class="text-muted mb-0"><%= pluralize(folder.vinyls.count, "record") %></p>
          </div>
          <button type="button" class="btn-close vinyl-folder-modal-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body vinyl-folder-modal-body">
          <% folder_vinyls = folder.vinyls.order(created_at: :desc) %>
          <% if folder_vinyls.any? %>
            <div class="row g-3">
              <% folder_vinyls.each do |vinyl| %>
                <% user_vinyl = @user_vinyls_by_vinyl_id[vinyl.id] %>
                <% vinyl_folder_ids = user_vinyl ? user_vinyl.folders.map(&:id) : [] %>

                <div class="col-12 col-md-6 col-xl-4" data-crate-card>
                  <%= render "vinyl_card",
                    vinyl: vinyl,
                    user_vinyl: user_vinyl,
                    vinyl_folder_ids: vinyl_folder_ids,
                    folders: @folders,
                    compact: true,
                    current_folder: folder %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="vinyl-folder-modal-empty">
              <p class="mb-0 text-muted">This crate is empty.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
